# Copy to .env and fill in your values
# Database Configuration
DB_HOST=your-host-mysql.services.clever-cloud.com
DB_PORT=3306
DB_USER=your-username
DB_PASSWORD=your-password
DB_NAME=your-database

# Flask Configuration
SECRET_KEY=your-secret-key-here
FLASK_ENV=development

# Google Email API
GOOGLE_CLIENT_ID=555803618353-hgfrvau2sobq2a6qb911u9n4otiqp0ju.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=DECRYPTED_GOOGLE_CLIENT_SECRET from creds.ejson
